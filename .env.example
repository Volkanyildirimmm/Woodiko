# Resend API Key (email gönderimi için)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Gönderici ve alıcı email adresleri
FROM_EMAIL=noreply@woodiko.com
TO_EMAIL=info@woodiko.com

# Site URL (production'da Vercel URL'i)
NEXT_PUBLIC_SITE_URL=https://woodiko.com

# WhatsApp numarası (başında + ve ülke kodu ile)
NEXT_PUBLIC_WHATSAPP_NUMBER=+905077347521

# ---- Analytics & Marketing ----
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager Container ID (GTM-XXXXXXX) - opsiyonel
NEXT_PUBLIC_GTM_ID=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversion API (server-side) Access Token
META_CAPI_ACCESS_TOKEN=

# Meta CAPI test event code (Events Manager > Test Events sekmesinden alınır)
META_CAPI_TEST_EVENT_CODE=

# Google Ads conversion takibi (AW-XXXXXXXXX) ve label'lar
# Lead = form gönderimi, Contact = WhatsApp/telefon tıklaması
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_CONTACT_LABEL=
